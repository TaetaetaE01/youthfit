# Spring Boot
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# PostgreSQL (RDS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=youthfit
DB_USER=youthfit
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Kakao OAuth (backend)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# Kakao OAuth (frontend - VITE_ prefix exposes to browser; NEVER put SECRET here)
VITE_KAKAO_CLIENT_ID=
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# JWT
JWT_SECRET=changeme-use-random-256bit-key
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=1209600

# AWS S3 (서비스별 IAM 키 정책)
#
# 정책: 루트 계정 액세스 키 사용 금지. 항상 서비스별 IAM 사용자 + 최소 권한 정책으로 발급받는다.
# 발급 절차: AWS Console > IAM > Users > 새 사용자 > 액세스 키 발급
#           > 정책: 특정 버킷 한정 (s3:PutObject, s3:GetObject, s3:HeadObject)
#                  또는 AmazonS3ReadOnlyAccess + 별도 PutObject 인라인 정책
# 발급된 키는 S3 외 다른 AWS 서비스 (EC2, RDS, IAM 등)에 권한 없어야 한다.
S3_REGION=ap-northeast-2
S3_BUCKET=youthfit-attachments
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Internal API (n8n -> Spring Boot)
INTERNAL_API_KEY=changeme

# Slack
SLACK_WEBHOOK_URL=

# n8n (self-host)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# 공공데이터포털 - 복지로 중앙부처 복지서비스 (NationalWelfareInformationsV001)
BOKJIRO_SERVICE_KEY=
